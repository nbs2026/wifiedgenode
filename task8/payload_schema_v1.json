{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IoT Sensor Payload Schema v1",
  "type": "object",
  "properties": {
    "temp_c": {
      "type": "number",
      "description": "Temperature reading in Celsius"
    },
    "humidity_pct": {
      "type": "number",
      "description": "Relative humidity percentage"
    },
    "soil_moisture_pct": {
      "type": "number",
      "description": "Soil moisture sensor reading"
    }
  },
  "required": [
    "temp_c",
    "humidity_pct",
    "soil_moisture_pct"
  ]
}
